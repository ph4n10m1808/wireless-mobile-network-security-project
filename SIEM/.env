# Local Kibana URL
LOCAL_KBN_URL=https://127.0.0.1:5601

# Local ES URL
LOCAL_ES_URL=https://127.0.0.1:9200

# Username for Kibana
ELASTIC_USERNAME=elastic

# Password for the 'elastic' user (at least 6 characters)
ELASTIC_PASSWORD=Vsl@2026

# Password for the 'kibana_system' user (at least 6 characters)
KIBANA_PASSWORD=Vsl@2026

# Version of Elastic products
STACK_VERSION=9.0.1
# Testing pre-releases? Use the SNAPSHOT option below:
# STACK_VERSION=8.11.0-SNAPSHOT

# Bulk Enable Detection Rules by OS
LinuxDR=0

WindowsDR=0

MacOSDR=0

# Set the cluster name
CLUSTER_NAME=WMNS_Project

# Set to "basic" or "trial" to automatically start the 30-day trial
LICENSE=basic

# Port to expose Elasticsearch HTTP API to the host
ES_PORT=9200

# Port to expose Kibana to the host
KIBANA_PORT=5601

# Increase or decrease based on the available host memory (in bytes)
MEM_LIMIT=2147483648
# Kibana Encryption Key (32+ bytes) for production sessions and saved objects
ENCRYPTION_KEY=21fa57c8131c7d194d420ab2b9252d368cbbc63d51cf062299413898d2824917
